# ==========================================================
# Example environment file
# Copy this file to .env and fill in your real values locally.
# ==========================================================

# Supabase PostgreSQL
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=
DB_PASSWORD=

# Customer Google Login
CUSTOMER_GOOGLE_CLIENT_ID=
CUSTOMER_GOOGLE_CLIENT_SECRET=
CUSTOMER_GOOGLE_REDIRECT_URI=http://localhost/store_management/google_callback.php

# Admin Google Login
ADMIN_GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_CLIENT_SECRET=
ADMIN_GOOGLE_REDIRECT_URI=http://localhost/store_management/admin/google_callback.php

# Google Maps
GOOGLE_MAPS_API_KEY=
COMPANY_MAP_QUERY=MY DREAM BIKE SDN BHD
COMPANY_MAP_LINK=
